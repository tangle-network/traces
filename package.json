{
  "name": "@tangle-network/traces",
  "version": "0.8.18",
  "description": "Point it at your coding-agent session traces (Claude Code, Codex, OpenCode, Gemini, Pi, …) and get failure-mode + efficiency findings. CLI + SDK over the @tangle-network/agent-eval analyst suite — observe live sessions, run your own analysts, redact, and upload to the Tangle Intelligence Platform.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tangle-network/traces.git"
  },
  "homepage": "https://github.com/tangle-network/traces#readme",
  "bugs": "https://github.com/tangle-network/traces/issues",
  "keywords": [
    "ai-agents",
    "observability",
    "tracing",
    "otlp",
    "claude-code",
    "codex",
    "opencode",
    "agent-eval",
    "llm",
    "coding-agent"
  ],
  "packageManager": "pnpm@10.33.4",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "traces": "dist/cli.js"
  },
  "files": [
    "dist",
    "install.sh",
    "README.md"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsup src/index.ts src/cli.ts --format esm --target node22 --clean --dts",
    "check:package": "node scripts/check-package-bin.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build && pnpm check:package"
  },
  "dependencies": {
    "@ax-llm/ax": "^19.0.45",
    "@tangle-network/agent-eval": "^0.100.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^8.1.2",
    "vitest": "^4.1.9"
  }
}
